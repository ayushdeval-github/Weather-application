# Server
PORT=3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/weather_db

# OpenWeatherMap API key — get one free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Default city for the background cron job
DEFAULT_CITY=Delhi

# Default country code (ISO 3166-1 alpha-2) — scopes all searches to this country
DEFAULT_COUNTRY=IN

# CORS origin — set to your frontend URL in production, leave * for development
CORS_ORIGIN=*
